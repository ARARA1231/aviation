<Window x:Class="NetworkAnalyzerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Анализатор сетевых подключений"
        Height="760"
        Width="1240"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,12"
                Background="#FF1F2937"
                CornerRadius="10">
            <StackPanel>
                <TextBlock Text="Анализатор сетевых подключений"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="WPF-приложение для просмотра интерфейсов, анализа URL/URI, ping, DNS и истории запросов"
                           Margin="0,6,0,0"
                           Foreground="#FFE5E7EB"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="240"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Сетевые интерфейсы" Padding="10">
                    <DockPanel>
                        <Button Content="Обновить список"
                                DockPanel.Dock="Top"
                                Height="32"
                                Margin="0,0,0,10"
                                Click="RefreshInterfacesButton_Click"/>

                        <ListBox ItemsSource="{Binding NetworkInterfaces}"
                                 SelectedItem="{Binding SelectedNetworkInterface, Mode=TwoWay}"
                                 DisplayMemberPath="DisplayName"/>
                    </DockPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="История проверенных URL" Padding="10">
                    <DockPanel>
                        <Button Content="Очистить историю"
                                DockPanel.Dock="Top"
                                Height="32"
                                Margin="0,0,0,10"
                                Click="ClearHistoryButton_Click"/>

                        <ListBox ItemsSource="{Binding UrlHistory}"
                                 DisplayMemberPath="DisplayText"
                                 MouseDoubleClick="HistoryListBox_MouseDoubleClick"/>
                    </DockPanel>
                </GroupBox>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Информация о выбранном интерфейсе" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNetworkInterface.Name}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNetworkInterface.Description}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="IP-адрес:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNetworkInterface.IpAddress}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Маска подсети:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNetworkInterface.SubnetMask}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="MAC-адрес:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedNetworkInterface.MacAddress}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Состояние:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedNetworkInterface.Status}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Скорость:" FontWeight="Bold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedNetworkInterface.Speed}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Тип интерфейса:" FontWeight="Bold"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedNetworkInterface.InterfaceType}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Проверка и анализ URL/URI" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Grid.Column="0"
                                 Height="34"
                                 Margin="0,0,10,10"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Height="34"
                                Content="Анализировать"
                                Click="AnalyzeUrlButton_Click"/>

                        <TextBlock Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Foreground="#FF6B7280"
                                   Text="Можно вводить как полный адрес (https://example.com/path?x=1), так и домен без протокола (example.com)."/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="4" Header="Результаты анализа" Padding="14">
                    <TextBox Text="{Binding AnalysisOutput}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="14"/>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>